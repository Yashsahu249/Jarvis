# Jarvis Configuration
# Copy to .env and fill in your values

# LLM Provider (ollama, groq, openrouter, gemini)
LLM_PROVIDER=ollama

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_MODEL=mistral

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tavily Search
TAVILY_API_KEY=

# Voice
STT_MODEL_SIZE=small
TTS_ENGLISH_MODEL=voices/en_US-lessac-medium.onnx
TTS_HINDI_MODEL=voices/hi_IN-pratham-medium.onnx
WAKE_WORD=jarvis
LISTEN_TIMEOUT=5
AUDIO_DEVICE=

# Memory
MEMORY_DB_PATH=data/memory.db
MEMORY_MAX_HISTORY=50
MEMORY_ENABLE_SUMMARIZATION=true

# Safety
AUTO_EXECUTE_SAFE=true
REQUIRE_CONFIRMATION=true
SANDBOX_ENABLED=true

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Browser
BROWSER_HEADLESS=true
BROWSER_VISIBLE=false
